-- Variables
local aimbotEnabled = false
local isRightClicking = false
local currentTarget = nil

local function isValidTarget(player)
    if not player or player == LocalPlayer or not player.Character then return false end
    local humanoid = player.Character:FindFirstChild("Humanoid")
    local head = player.Character:FindFirstChild("Head")
    if not humanoid or not head or humanoid.Health <= 0 then return false end
    return true
end

local function getClosestPlayerInFOV()
    local closestPlayer = nil
    local shortestDistance = rangeSlider.getValue()
    
    for _, player in pairs(Players:GetPlayers()) do
        if isValidTarget(player) then
            local head = player.Character:FindFirstChild("Head")
            local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
            
            if onScreen then
                local mousePos = UserInputService:GetMouseLocation()
                local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                
                if distance < shortestDistance then
                    closestPlayer = player
                    shortestDistance = distance
                end
            end
        end
    end
    
    return closestPlayer
end

local function aimAtHead(target)
    if not target or not target.Character then return end
    local head = target.Character:FindFirstChild("Head")
    if not head then return end
    
    -- Calculate exact center of head
    local headCFrame = head.CFrame
    local headCenter = headCFrame.Position
    
    local screenPos, onScreen = Camera:WorldToViewportPoint(headCenter)
    if not onScreen then return end
    
    local mousePos = UserInputService:GetMouseLocation()
    local targetPos = Vector2.new(screenPos.X, screenPos.Y)
    local currentPos = Vector2.new(mousePos.X, mousePos.Y)
    local direction = targetPos - currentPos
    local distance = direction.Magnitude
    
    -- Anti-spin fix: Don't aim if already very close
    if aimbotMode == "hard" and distance < 3 then return end
    if aimbotMode == "smooth" and distance < 1 then return end
    
    local strength
    if aimbotMode == "smooth" then
        strength = 0.35
    else
        -- Hard mode with anti-spin cap
        strength = math.min(0.8, distance / 50)
    end
    
    local pullAmount = direction * strength
    mousemoverel(pullAmount.X, pullAmount.Y)
end

local function updateLockIndicator(target)
    if target and target.Character and not hideCursor then
        local head = target.Character:FindFirstChild("Head")
        if head then
            local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
            if onScreen then
                LockIndicator.Position = UDim2.new(0, screenPos.X - 20, 0, screenPos.Y - 20)
                LockIndicator.Visible = true
                
                -- Pulse effect
                local pulse = math.sin(tick() * 10) * 2
                LockIndicator.Size = UDim2.new(0, 40 + pulse, 0, 40 + pulse)
                return
            end
        end
    end
    LockIndicator.Visible = false
end

local aimbotConnection
local function startAimbot()
    if aimbotConnection then return end
    
    aimbotConnection = RunService.RenderStepped:Connect(function()
        if aimbotEnabled and isRightClicking then
            if currentTarget and isValidTarget(currentTarget) then
                aimAtHead(currentTarget)
                updateLockIndicator(currentTarget)
                CircleOuter.Color = Color3.fromRGB(255, 80, 80)
            else
                local target = getClosestPlayerInFOV()
                if target then
                    currentTarget = target
                    aimAtHead(target)
                    updateLockIndicator(target)
                    CircleOuter.Color = Color3.fromRGB(255, 80, 80)
                else
                    currentTarget = nil
                    LockIndicator.Visible = false
                    CircleOuter.Color = Color3.fromRGB(100, 150, 255)
                end
            end
        else
            currentTarget = nil
            LockIndicator.Visible = false
            CircleOuter.Color = Color3.fromRGB(100, 150, 255)
        end
    end)
end

local function stopAimbot()
    if aimbotConnection then
        aimbotConnection:Disconnect()
        aimbotConnection = nil
    end
    currentTarget = nil
    LockIndicator.Visible = false
end

mainToggle.MouseButton1Click:Connect(function()
    aimbotEnabled = not aimbotEnabled
    
    if aimbotEnabled then
        statusLabel.Text = " Status: ON"
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        if not hideCursor then FOVCircle.Visible = true end
        startAimbot()
        
        TweenService:Create(mainToggle, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(80, 200, 120)}):Play()
        TweenService:Create(mainToggleCircle, TweenInfo.new(0.3), {Position = UDim2.new(1, -31, 0.5, -13.5)}):Play()
    else
        statusLabel.Text = "Status: OFF"
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        FOVCircle.Visible = false
        stopAimbot()
        
        TweenService:Create(mainToggle, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(40, 40, 50)}):Play()
        TweenService:Create(mainToggleCircle, TweenInfo.new(0.3), {Position = UDim2.new(0, 4, 0.5, -13.5)}):Play()
    end
end)

